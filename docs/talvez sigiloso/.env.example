# IARA - Template de Ambiente
# Copie este arquivo para .env e preencha com suas chaves

# Mensageiro (Opcional se não usar Telegram)
TELEGRAM_BOT_TOKEN=seu_token_aqui
USER_ID_ALLOWED=seu_id_telegram

# Inteligência Artificial (Provedores LLM)
GROQ_API_KEY=sua_chave_groq
GROQ_API_KEY_2=sua_chave_groq_secundaria
CEREBRAS_API_KEY=sua_chave_cerebras
CEREBRAS_API_KEY_2=sua_chave_cerebras_secundaria
OPENROUTER_API_KEY=sua_chave_openrouter
NVIDIA_NIM_API_KEY=sua_chave_nvidia
GEMINI_API_KEY=sua_chave_gemini
MISTRAL_API_KEY=sua_chave_mistral
E2B_API_KEY=sua_chave_e2b
COHERE_API_KEY=sua_chave_cohere
SAMBANOVA_API_KEY=sua_chave_sambanova
# Ferramentas de Pesquisa
BRAVE_API_KEY=sua_chave_brave_search

# Extensões e Outros
COMPOSIO_API_KEY=sua_chave_composio
